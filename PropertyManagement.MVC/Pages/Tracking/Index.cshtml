@page
@model PropertyManagement.MVC.Pages.Tracking.IndexModel
@{
    ViewData["Title"] = "Public Tracking";
}

<h1>Public Tracking / Lookup</h1>

<form method="post" class="mb-3">
    <div class="mb-3">
        <label asp-for="Input.Reference" class="form-label"></label>
        <input asp-for="Input.Reference" class="form-control" />
        <span asp-validation-for="Input.Reference" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Lookup</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@if (!string.IsNullOrEmpty(Model.Input.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @Model.Input.ErrorMessage
    </div>
}
else if (Model.Input.Found)
{
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Tracking result</h5>
            @if (!string.IsNullOrEmpty(Model.Input.JsonResult))
            {
                <pre style="white-space: pre-wrap;">@Model.Input.JsonResult</pre>
            }
            else if (!string.IsNullOrEmpty(Model.Input.RawResult))
            {
                <pre style="white-space: pre-wrap;">@Model.Input.RawResult</pre>
            }
            else
            {
                <p>No content returned from API.</p>
            }
        </div>
    </div>
}