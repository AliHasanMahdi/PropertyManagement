@model PropertyManagement.API.Models.MaintenanceRequest
@{
    ViewData["Title"] = "Request Details";
}

<div class="container mt-4">
    <h2 class="mb-4">?? Request Details</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">? @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">? @TempData["Error"]</div>
    }

    <div class="card shadow">
        <div class="card-body">
            <h5>@Model.Title <small class="text-muted">(@Model.TicketNumber)</small></h5>
            <p>@Model.Description</p>

            <dl class="row">
                <dt class="col-sm-3">Tenant</dt>
                <dd class="col-sm-9">@Model.Tenant?.FullName</dd>

                <dt class="col-sm-3">Unit</dt>
                <dd class="col-sm-9">@Model.Unit?.UnitNumber</dd>

                <dt class="col-sm-3">Category</dt>
                <dd class="col-sm-9">@Model.Category</dd>

                <dt class="col-sm-3">Priority</dt>
                <dd class="col-sm-9">@Model.Priority</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>

                <dt class="col-sm-3">Created</dt>
                <dd class="col-sm-9">@Model.CreatedAt.ToString("g")</dd>

                @if (Model.ResolvedAt != null)
                {
                    <dt class="col-sm-3">Resolved At</dt>
                    <dd class="col-sm-9">@Model.ResolvedAt?.ToString("g")</dd>
                }
            </dl>

            <div>
                <a asp-action="AssignedRequests" class="btn btn-secondary">Back</a>
                @if (Model.Status == "Assigned")
                {
                    <form asp-action="StartWork" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-primary">Start Work</button>
                    </form>
                }
                else if (Model.Status == "InProgress")
                {
                    <form asp-action="Resolve" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success">Resolve</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
